//Largest Element in The Array
        OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
ARRAY DW 0004H,0001H,0003H,0002H,0000H
LARGE DW 0000H
COUNT EQU 0005H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
        MOV AX,DATA
        MOV DS,AX
        MOV DX,COUNT
        DEC DX
L2:     MOV CX,DX
        MOV SI,OFFSET ARRAY
L1:     MOV AX,[SI]
        CMP AX,2[SI]
        JNC L3
        XCHG AX,2[SI]
        XCHG AX,[SI]
L3:     INC SI
        INC SI
        LOOP L1
        DEC DX
        JNZ L2
        LEA SI,ARRAY
        MOV AX,[SI]
        MOV LARGE,AX
        HLT
CODE ENDS
END
