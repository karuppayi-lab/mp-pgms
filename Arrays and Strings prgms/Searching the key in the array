//Searching the key in the array
        OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
ARRAY DW 0004H,0001H,0003H,0002H,0005H
KEY DW 0003H
COUNT EQU 0005H
RES DB 00H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
        MOV AX,DATA
        MOV DS,AX
        MOV CX,COUNT
        MOV SI,OFFSET ARRAY
L2:     MOV AX,[SI]
        CMP AX,KEY
        JZ L1
        INC SI
        INC SI
        DEC CX
        JNZ L2
        JMP L3
L1:     MOV RES,01H
L3:     HLT
CODE ENDS
END
