//div of 16 bit numbers
        OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
NO1L DW AAAAH
NO1M DW 0000H
NO2 DW BBBBH
QUO DW 0000H
REM DW 0000H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
        MOV AX,DATA
        MOV DS,AX
        MOV AX,NO1L
        MOV DX,NO1M
        MOV BX,NO2
        DIV BX
        MOV QUO,AX
        MOV REM,DX
CODE ENDS
END

